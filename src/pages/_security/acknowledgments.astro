---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Security Acknowledgments — Denazen"
  description="Security researchers who have responsibly reported issues to Denazen."
  pathname="/security/acknowledgments/"
>
  <section>
    <div class="container-narrow legal-content">
      <h1>Security Acknowledgments</h1>
      <p class="lead mt-3">
        Denazen thanks the following security researchers for responsibly reporting issues.
      </p>
      <p>
        <em>No reports to acknowledge yet. This list will grow as researchers contribute.</em>
      </p>
      <p>
        If you have reported an issue and would like to be listed here, let us know in your report.
      </p>
      <p class="mt-4">
        See our <a href="/security/">Security Policy</a> for how to submit a report.
      </p>
    </div>
  </section>
</Base>
