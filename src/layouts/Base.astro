---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { defaultLang, type Lang } from '../i18n/config';
import { useTranslations, getAlternateUrls, stripLangFromPath } from '../i18n/utils';
import { localizeAsset, publicAssetVersion } from '../i18n/assets';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogImage?: string;
  pathname?: string;
  lang?: Lang;
}

const SHARE_TAGLINE_EN = 'Where real connection takes root.';
const SHARE_TAGLINE_ES = 'Donde la conexión real echa raíces.';

const SHARE_DESCRIPTION_EN =
  'Privacy inspired by Signal. Connection like early Facebook. Freedom and choice of Bluesky. Share with the people you trust — privately, authentically, securely.';
const SHARE_DESCRIPTION_ES =
  'Privacidad inspirada en Signal. Conexión como en los primeros días de Facebook. Libertad y elección de Bluesky. Comparte con las personas en las que confías — de forma privada, auténtica y segura.';

const {
  title,
  description,
  ogTitle,
  ogImage = '/images/og-default.png',
  pathname,
  lang = defaultLang,
} = Astro.props;

const resolvedDescription =
  description ?? (lang === 'es' ? SHARE_DESCRIPTION_ES : SHARE_DESCRIPTION_EN);

const t = useTranslations(lang);
const site = Astro.site ?? new URL('https://www.denazen.com');
const canonical = new URL(Astro.url.pathname, site).href;
const currentPath = pathname ?? Astro.url.pathname;
const langlessPath = stripLangFromPath(currentPath);
const alternates = getAlternateUrls(currentPath, site);
const xDefault = alternates.find((a) => a.lang === defaultLang)?.href;
const ogImageResolved = localizeAsset(ogImage, lang);
const ogImageVersion = publicAssetVersion(ogImageResolved);
const ogImagePath = ogImageVersion ? `${ogImageResolved}?v=${ogImageVersion}` : ogImageResolved;
const ogImageUrl = new URL(ogImagePath, site).href;
const shareTagline = lang === 'es' ? SHARE_TAGLINE_ES : SHARE_TAGLINE_EN;
const ogTitleResolved = ogTitle ?? `Rhize — ${shareTagline}`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.lang} href={a.href} />
    ))}
    {xDefault && <link rel="alternate" hreflang="x-default" href={xDefault} />}

    <link rel="icon" type="image/png" href="/favicon/icon.png?v=5" />
    <link rel="apple-touch-icon" href="/favicon/icon.png?v=5" />
    <meta name="theme-color" content="#1F7A2C" />

    <meta property="og:site_name" content="Rhize" />
    <meta property="og:title" content={ogTitleResolved} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`Rhize — ${shareTagline}`} />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitleResolved} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={`Rhize — ${shareTagline}`} />

    <link rel="preload" href="/fonts/inter/Inter-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter/Inter-ExtraBold.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <a href="#main" class="sr-only">{t('nav.skipToContent')}</a>
    <Nav lang={lang} currentPath={currentPath} langlessPath={langlessPath} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
