---
import type { Lang } from '../../i18n/config';
import { localizeAsset } from '../../i18n/assets';
import type enContent from '../../content/pages/index.en';

interface Props {
  lang: Lang;
  content: typeof enContent;
}

const { lang, content: c } = Astro.props;
const img = (p: string) => localizeAsset(p, lang);
---
<!-- Hero -->
<section class="home-hero">
  <div class="container">
    <div class="home-grid">
      <div class="home-text">
        <h1>{c.hero.heading}</h1>
        <p class="home-hero-lines">
          {c.hero.lines.map((line, i) => (
            <>
              {line}
              {i < c.hero.lines.length - 1 && <br />}
            </>
          ))}
        </p>
        <p class="home-hero-tagline">{c.hero.tagline}</p>
      </div>
      <div class="home-visual home-hero-visual">
        <img class="home-hero-phone home-hero-phone-back" src={img(c.hero.imagePublic.src)} alt={c.hero.imagePublic.alt} width="560" height="1111" />
        <img class="home-hero-phone home-hero-phone-front" src={img(c.hero.imagePrivate.src)} alt={c.hero.imagePrivate.alt} width="560" height="1111" />
      </div>
    </div>
  </div>
</section>

<!-- Subhead -->
<section class="section-tint home-subhead">
  <div class="container-narrow">
    <p class="home-subhead-text">
      {c.subhead.lines.map((line, i) => (
        <>
          {line}
          {i < c.subhead.lines.length - 1 && <br />}
        </>
      ))}
    </p>
  </div>
</section>

<!-- What Denazen Is -->
<section class="home-prose">
  <div class="container">
    <div class="home-grid">
      <div class="home-text">
        <h2>{c.whatDenazen.heading}</h2>
        {c.whatDenazen.paragraphs.map((p) => <p>{p}</p>)}
        <p class="home-prose-resolution">{c.whatDenazen.resolution}</p>
        <ul class="home-list">
          {c.whatDenazen.list.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="home-visual">
        <img src={img(c.whatDenazen.image.src)} alt={c.whatDenazen.image.alt} width="560" height="1111" />
      </div>
    </div>
  </div>
</section>

<!-- Privacy -->
<section class="section-tint home-prose">
  <div class="container">
    <div class="home-grid reversed">
      <div class="home-text">
        <h2>{c.privacy.heading}</h2>
        {c.privacy.paragraphs.map((p) => <p>{p}</p>)}
        <p class="home-prose-closer">{c.privacy.closer}</p>
      </div>
      <div class="home-visual">
        <img src={img(c.privacy.image.src)} alt={c.privacy.image.alt} width="560" height="1111" />
      </div>
    </div>
  </div>
</section>

<!-- Freedom & Control -->
<section class="home-prose">
  <div class="container">
    <div class="home-grid">
      <div class="home-text">
        <h2>{c.freedom.heading}</h2>
        <p>{c.freedom.intro}</p>
        <ul class="home-list">
          {c.freedom.list.map((item) => <li>{item}</li>)}
        </ul>
        {c.freedom.closing.map((p) => <p>{p}</p>)}
      </div>
      <div class="home-visual">
        <img src={img(c.freedom.image.src)} alt={c.freedom.image.alt} width="560" height="1111" />
      </div>
    </div>
  </div>
</section>

<!-- Values -->
<section class="section-dark home-prose home-prose--dark">
  <div class="container-narrow">
    <h2>{c.values.heading}</h2>
    {c.values.paragraphs.map((p) => <p>{p}</p>)}
  </div>
</section>

<!-- Closing -->
<section class="home-closing">
  <div class="container-narrow">
    <h2>{c.closing.line}</h2>
  </div>
</section>
