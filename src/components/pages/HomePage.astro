---
import WaitlistForm from '../WaitlistForm.astro';
import type { Lang } from '../../i18n/config';
import { localizeAsset } from '../../i18n/assets';
import type enContent from '../../content/pages/index.en';

interface Props {
  lang: Lang;
  content: typeof enContent;
}

const { lang, content: c } = Astro.props;
const img = (p: string) => localizeAsset(p, lang);
---
<!-- Hero -->
<section class="home-hero">
  <div class="container">
    <div class="home-grid">
      <div class="home-text">
        <h1 set:html={c.hero.heading}></h1>
        {c.hero.subheading && (
          <p class="home-hero-subhead" set:html={c.hero.subheading} />
        )}
        <p class="home-hero-lines">
          {c.hero.linesBefore.map((line) => (
            <>
              <Fragment set:html={line} />
              <br />
            </>
          ))}
          <span class="home-hero-rotator-line">
            <Fragment set:html={c.hero.rotator.prefix} /><span class="word-rotator">
              {c.hero.rotator.words.map((w, i) => (
                <span class={`word${i === 0 ? ' is-active' : ''}`}>{w}</span>
              ))}
            </span><Fragment set:html={c.hero.rotator.suffix} />
          </span>
          {c.hero.linesAfter.map((line) => (
            <>
              <br />
              <Fragment set:html={line} />
            </>
          ))}
        </p>
        <p class="home-hero-tagline">
          {c.hero.tagline.map((line, i) => (
            <>
              {line}
              {i < c.hero.tagline.length - 1 && <br />}
            </>
          ))}
        </p>
        <div class="home-hero-cta">
          <WaitlistForm lang={lang} id="waitlist" buttonLabel={c.hero.waitlistButton} note={c.hero.waitlistNote} />
        </div>
      </div>
      <div class="home-visual home-hero-visual">
        <img class="home-hero-phone home-hero-phone-back" src={img(c.hero.imagePublic.src)} alt={c.hero.imagePublic.alt} width="560" height="1112" />
        <img class="home-hero-phone home-hero-phone-front" src={img(c.hero.imagePrivate.src)} alt={c.hero.imagePrivate.alt} width="560" height="1112" />
      </div>
    </div>
  </div>
</section>

<!-- Privacy -->
<section class="section-tint home-prose">
  <div class="container">
    <div class="home-grid">
      <div class="home-text">
        <h2>{c.privacy.heading}</h2>
        {c.privacy.paragraphs.map((p) => <p set:html={p} />)}
        <p class="home-prose-closer">{c.privacy.closer}</p>
      </div>
      <div class="home-visual">
        <img src={img(c.privacy.image.src)} alt={c.privacy.image.alt} width="560" height="1112" />
      </div>
    </div>
  </div>
</section>

<!-- What Rhize Is -->
<section class="home-prose">
  <div class="container">
    <div class="home-grid reversed">
      <div class="home-text">
        <h2>{c.whatRhize.heading}</h2>
        {c.whatRhize.paragraphs.map((p) => <p set:html={p} />)}
        <p class="home-prose-resolution">{c.whatRhize.resolution}</p>
        <ul class="home-list">
          {c.whatRhize.list.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="home-visual">
        <img src={img(c.whatRhize.image.src)} alt={c.whatRhize.image.alt} width="560" height="1112" />
      </div>
    </div>
  </div>
</section>

<!-- Freedom & Control -->
<section class="section-tint home-prose">
  <div class="container">
    <div class="home-grid">
      <div class="home-text">
        <h2>{c.freedom.heading}</h2>
        <p>{c.freedom.intro}</p>
        <ul class="home-list">
          {c.freedom.list.map((item) => <li>{item}</li>)}
        </ul>
        {c.freedom.closing.map((p) => <p>{p}</p>)}
      </div>
      <div class="home-visual">
        <img src={img(c.freedom.image.src)} alt={c.freedom.image.alt} width="560" height="1112" />
      </div>
    </div>
  </div>
</section>

<!-- Why Rhize -->
<section class="home-prose">
  <div class="container-narrow">
    <h2>{c.whyRhize.heading}</h2>
    <p class="home-prose-resolution">{c.whyRhize.subheading}</p>
    {c.whyRhize.paragraphs.map((p) => <p>{p}</p>)}
  </div>
</section>

<!-- Values -->
<section class="section-dark home-prose home-prose--dark">
  <div class="container-narrow">
    <h2>{c.values.heading}</h2>
    {c.values.paragraphs.map((p) => <p>{p}</p>)}
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('.word-rotator').forEach((rotator) => {
    const words = Array.from(rotator.querySelectorAll<HTMLElement>('.word'));
    if (words.length < 2) return;
    let active = 0;
    setInterval(() => {
      words[active].classList.remove('is-active');
      words[active].classList.add('was-active');
      active = (active + 1) % words.length;
      words[active].classList.remove('was-active');
      words[active].classList.add('is-active');
    }, 3000);
  });
</script>
