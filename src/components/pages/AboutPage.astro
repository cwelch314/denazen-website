---
import WaitlistForm from '../WaitlistForm.astro';
import type { Lang } from '../../i18n/config';
import { localizeAsset } from '../../i18n/assets';
import type enContent from '../../content/pages/about.en';

interface Props {
  lang: Lang;
  content: typeof enContent;
}

const { lang, content: c } = Astro.props;
const img = (p: string) => localizeAsset(p, lang);
---
<!-- Hero -->
<section>
  <div class="container-narrow">
    <h1>{c.hero.heading}</h1>
    <p class="lead mt-3">{c.hero.lead}</p>
    <p class="about-pull">{c.hero.pullQuote}</p>
    <p>{c.hero.body}</p>
  </div>
</section>

<!-- Why we built it -->
<section class="section-tint">
  <div class="container-narrow legal-content">
    <h2>{c.whyBuilt.heading}</h2>
    {c.whyBuilt.paragraphs.map((p) => <p>{p}</p>)}
  </div>
</section>

<!-- What makes us different -->
<section>
  <div class="container-narrow legal-content">
    <h2>{c.whatMakesDifferent.heading}</h2>
    <p>{c.whatMakesDifferent.intro}</p>
    <ul>
      {c.whatMakesDifferent.list.map((item) => <li>{item}</li>)}
    </ul>
    {c.whatMakesDifferent.trailingParagraphs.map((p) => <p>{p}</p>)}
  </div>
</section>

<!-- How we think about privacy -->
<section class="section-tint">
  <div class="container-narrow legal-content">
    <h2>{c.howPrivacy.heading}</h2>
    {c.howPrivacy.paragraphs.map((p) => <p>{p}</p>)}
  </div>
</section>

<!-- Built to stay aligned -->
<section>
  <div class="container-narrow legal-content">
    <h2>{c.alignment.heading}</h2>
    {c.alignment.paragraphs.map((p) => <p>{p}</p>)}
  </div>
</section>

<!-- A different kind of company -->
<section class="section-tint">
  <div class="container-narrow legal-content">
    <h2>{c.pbc.heading}</h2>
    {c.pbc.paragraphs.map((p) => <p>{p}</p>)}
    <ul>
      {c.pbc.list.map((item) => <li>{item}</li>)}
    </ul>
    {c.pbc.trailingParagraphs.map((p) => <p>{p}</p>)}
  </div>
</section>

<!-- Who we are -->
<section>
  <div class="container-narrow legal-content">
    <h2>{c.team.heading}</h2>
    <p>{c.team.intro}</p>
    {c.team.founders.map((f) => (
      <div class="founder">
        <img class="founder-photo" src={img(f.photo)} alt={f.photoAlt} width="96" height="96" />
        <p><strong>{f.name}</strong>{f.bio}</p>
      </div>
    ))}
  </div>
</section>

<!-- Where we are -->
<section class="section-tint">
  <div class="container-narrow legal-content">
    <h2>{c.whereWeAre.heading}</h2>
    {c.whereWeAre.paragraphs.map((p) => <p>{p}</p>)}
  </div>
</section>

<!-- CTA -->
<section class="section-dark">
  <div class="container">
    <div class="section-heading">
      <h2>{c.cta.heading}</h2>
      <p>{c.cta.body}</p>
    </div>
    <div style="display:flex; justify-content:center;">
      <div>
        <WaitlistForm lang={lang} id="waitlist-about" buttonLabel={c.cta.waitlistButton} />
      </div>
    </div>
  </div>
</section>
