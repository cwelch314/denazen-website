---
import type { Lang } from '../../i18n/config';
import { localizePath } from '../../i18n/utils';
import { localizeAsset } from '../../i18n/assets';
import type enContent from '../../content/pages/security-architecture.en';

interface Props {
  lang: Lang;
  content: typeof enContent;
}

const { lang, content: c } = Astro.props;
const img = (p: string) => localizeAsset(p, lang);
---
<section>
  <div class="container">
    <div style="max-width: 44rem; margin-bottom: 3rem;">
      <h1>{c.heading}</h1>
      <p class="lead mt-3">{c.lead}</p>
      <p class="mt-3" style="color: var(--c-text-muted); font-size: 0.95rem;">
        {c.plainLang.before}<a href={localizePath('/faq/', lang)}>{c.plainLang.linkText}</a>{c.plainLang.after}
      </p>
      <p class="mt-2" style="color: var(--c-text-muted); font-size: 0.95rem;">
        {c.lastUpdated.before}<time datetime={c.lastUpdated.date}>{c.lastUpdated.text}</time>{c.lastUpdated.between}<a href={localizePath('/security/changelog/', lang)}>{c.lastUpdated.linkText}</a>
      </p>
      <aside class="draft-notice" role="note">
        <strong>{c.draftNotice.title}</strong>
        <p>{c.draftNotice.body}</p>
      </aside>
    </div>

    <div class="doc-layout">
      <aside class="doc-toc" aria-label="On this page">
        <details open class="doc-toc-details">
          <summary class="doc-toc-summary">{c.toc.heading}</summary>
          <h4>{c.toc.heading}</h4>
          <ul>
            {c.toc.sections.map((s) => <li><a href={`#${s.id}`}>{s.label}</a></li>)}
          </ul>
        </details>
      </aside>
      <script is:inline>
        if (window.matchMedia('(max-width: 900px)').matches) {
          document.querySelector('.doc-toc-details')?.removeAttribute('open');
        }
        document.querySelectorAll('.doc-toc-details a').forEach((a) => {
          a.addEventListener('click', () => {
            if (window.matchMedia('(max-width: 900px)').matches) {
              document.querySelector('.doc-toc-details')?.removeAttribute('open');
            }
          });
        });
      </script>

      <article class="doc-content">
        <div class="doc-lead">
          {c.preambleBlocks.filter((b) => b.kind === 'p').slice(0, 1).map((b) => (
            <p set:html={(b as { kind: 'p'; html: string }).html} />
          ))}
        </div>

        {c.preambleBlocks.slice(1).map((b) => {
          if (b.kind === 'p') return <p set:html={b.html} />;
          if (b.kind === 'ol') return <ol>{b.items.map((i) => <li set:html={i} />)}</ol>;
          if (b.kind === 'ul') return <ul>{b.items.map((i) => <li set:html={i} />)}</ul>;
          if (b.kind === 'hr') return <hr />;
          return null;
        })}

        {c.sections.map((section) => (
          <>
            <h2 id={section.id}>
              {section.heading} <a class="anchor-link" href={`#${section.id}`} aria-label="Permalink">#</a>
            </h2>
            {section.blocks.map((b) => {
              if (b.kind === 'p') return <p set:html={b.html} />;
              if (b.kind === 'h3') {
                if (b.id) {
                  return (
                    <h3 id={b.id}>
                      {b.text} <a class="anchor-link" href={`#${b.id}`} aria-label="Permalink">#</a>
                    </h3>
                  );
                }
                return <h3>{b.text}</h3>;
              }
              if (b.kind === 'h4') return <h4 class="doc-subhead">{b.text}</h4>;
              if (b.kind === 'ul') return <ul>{b.items.map((i) => <li set:html={i} />)}</ul>;
              if (b.kind === 'ol') return <ol>{b.items.map((i) => <li set:html={i} />)}</ol>;
              if (b.kind === 'table') {
                const tableClass = b.className;
                return (
                  <div class="table-wrap">
                    <table class={tableClass}>
                      <thead>
                        <tr>{b.headers.map((h) => <th set:html={h} />)}</tr>
                      </thead>
                      <tbody>
                        {b.rows.map((row) => (
                          <tr>{row.map((cell) => <td set:html={cell} />)}</tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                );
              }
              if (b.kind === 'code') return <pre><code>{b.text}</code></pre>;
              if (b.kind === 'callout') {
                const calloutClass = b.variant === 'invariant' ? 'callout callout-invariant' : 'callout callout-status';
                return (
                  <aside class={calloutClass} role="note">
                    <span class="callout-label">{b.label}</span>
                    <p>{b.body}</p>
                  </aside>
                );
              }
              if (b.kind === 'figure') {
                return (
                  <figure>
                    <img src={img(b.src)} alt={b.alt} width={b.width} height={b.height} />
                    <figcaption>{b.caption}</figcaption>
                  </figure>
                );
              }
              if (b.kind === 'hr') return <hr />;
              return null;
            })}
          </>
        ))}
      </article>
    </div>
  </div>
</section>
