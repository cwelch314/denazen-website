---
import { defaultLang, type Lang } from '../i18n/config';
import { useTranslations, localizePath } from '../i18n/utils';
import { localizeAsset } from '../i18n/assets';

interface Props {
  lang?: Lang;
}
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={localizePath('/', lang)} class="brand" aria-label={t('nav.brandAria')}>
          <img src={localizeAsset('/images/brand/fox.png', lang)} alt="" class="brand-fox" width="40" height="40" />
          <span class="brand-text">Denazen</span>
        </a>
        <p>{t('footer.tagline')}</p>
      </div>

      <div class="footer-col">
        <h4>{t('footer.product')}</h4>
        <ul>
          <li><a href={localizePath('/', lang)}>{t('footer.home')}</a></li>
          <li><a href={localizePath('/faq/', lang)}>{t('footer.faq')}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>{t('footer.company')}</h4>
        <ul>
          <li><a href={localizePath('/about/', lang)}>{t('footer.about')}</a></li>
          <li><a href={`${localizePath('/', lang)}#waitlist`}>{t('footer.joinAlpha')}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>{t('footer.legal')}</h4>
        <ul>
          <li><a href={localizePath('/privacy/', lang)}>{t('footer.privacy')}</a></li>
          <li><a href={localizePath('/terms/', lang)}>{t('footer.terms')}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>{t('footer.connect')}</h4>
        <ul>
          <li><a href="https://bsky.app" target="_blank" rel="noopener">{t('footer.bluesky')}</a></li>
          <li><a href="https://github.com" target="_blank" rel="noopener">{t('footer.github')}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} Denazen. {t('footer.rights')}</span>
      <span>{t('footer.builtOn')}</span>
    </div>
  </div>
</footer>
