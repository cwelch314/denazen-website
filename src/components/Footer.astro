---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="brand" aria-label="Denazen home">
          <img src="/images/brand/fox.png" alt="" class="brand-fox" width="40" height="40" />
          <span class="brand-text">Denazen</span>
        </a>
        <p>Public when you want. Private when it matters. A privacy-first social network built on Bluesky.</p>
      </div>

      <div class="footer-col">
        <h4>Product</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/faq/">FAQ</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="/about/">About</a></li>
          <li><a href="/#waitlist">Join the alpha</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Legal</h4>
        <ul>
          <li><a href="/privacy/">Privacy</a></li>
          <li><a href="/terms/">Terms</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Connect</h4>
        <ul>
          <li><a href="https://bsky.app" target="_blank" rel="noopener">Bluesky</a></li>
          <li><a href="https://github.com" target="_blank" rel="noopener">GitHub</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} Denazen. All rights reserved.</span>
      <span>Built on the AT Protocol.</span>
    </div>
  </div>
</footer>
