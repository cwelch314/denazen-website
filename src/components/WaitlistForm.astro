---
import { defaultLang, type Lang } from '../i18n/config';
import { useTranslations } from '../i18n/utils';

interface Props {
  buttonLabel?: string;
  note?: string;
  id?: string;
  lang?: Lang;
}

const { id = 'waitlist', lang = defaultLang, buttonLabel, note } = Astro.props;
const t = useTranslations(lang);
const resolvedButton = buttonLabel ?? t('waitlist.buttonDefault');
const resolvedNote = note ?? t('waitlist.noteDefault');
---
<form
  class="waitlist"
  action="/api/waitlist"
  method="POST"
  id={id}
  novalidate
  data-msg-empty={t('waitlist.errorEmpty')}
  data-msg-submitting={t('waitlist.submitting')}
  data-msg-generic={t('waitlist.errorGeneric')}
  data-msg-network={t('waitlist.errorNetwork')}
  data-msg-success-title={t('waitlist.successTitle')}
  data-msg-success-body={t('waitlist.successBody')}
>
  <label for={`${id}-email`} class="sr-only">{t('waitlist.emailAria')}</label>
  <input
    id={`${id}-email`}
    name="email"
    type="email"
    required
    placeholder={t('waitlist.placeholder')}
    autocomplete="email"
    spellcheck="false"
  />
  <button type="submit" class="btn btn-primary">{resolvedButton}</button>
</form>
<p class="waitlist-note">{resolvedNote}</p>

<script>
  const forms = document.querySelectorAll<HTMLFormElement>('form.waitlist');

  forms.forEach((form) => {
    const msgs = {
      empty: form.dataset.msgEmpty ?? 'Please enter your email.',
      submitting: form.dataset.msgSubmitting ?? 'Submitting…',
      generic: form.dataset.msgGeneric ?? 'Something went wrong. Please try again.',
      network: form.dataset.msgNetwork ?? 'Network error. Please try again.',
      successTitle: form.dataset.msgSuccessTitle ?? 'You’re on the list.',
      successBody: form.dataset.msgSuccessBody ?? 'We’ll be in touch when your invite is ready.',
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const input = form.querySelector<HTMLInputElement>('input[type="email"]');
      const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (!input || !button) return;

      const email = input.value.trim();
      if (!email) {
        showError(form, msgs.empty);
        return;
      }

      clearError(form);
      const originalLabel = button.textContent;
      button.disabled = true;
      input.disabled = true;
      button.textContent = msgs.submitting;

      try {
        const response = await fetch('/api/waitlist', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify({ email }),
        });
        const data = (await response.json().catch(() => ({}))) as { ok?: boolean; error?: string };

        if (response.ok && data.ok) {
          showSuccess(form, msgs.successTitle, msgs.successBody);
          return;
        }
        showError(form, data.error ?? msgs.generic);
      } catch {
        showError(form, msgs.network);
      } finally {
        if (form.isConnected) {
          button.disabled = false;
          input.disabled = false;
          button.textContent = originalLabel;
        }
      }
    });
  });

  function showSuccess(form: HTMLFormElement, title: string, body: string) {
    const note = form.nextElementSibling as HTMLElement | null;
    const success = document.createElement('div');
    success.className = 'waitlist-success';
    success.setAttribute('role', 'status');
    const strong = document.createElement('strong');
    strong.textContent = `✓ ${title}`;
    success.appendChild(strong);
    success.appendChild(document.createTextNode(' ' + body));
    form.replaceWith(success);
    if (note && note.classList.contains('waitlist-note')) note.remove();
  }

  function showError(form: HTMLFormElement, message: string) {
    let el = form.parentElement?.querySelector<HTMLElement>(`.waitlist-error[data-for="${form.id}"]`);
    if (!el) {
      el = document.createElement('p');
      el.className = 'waitlist-error';
      el.setAttribute('role', 'alert');
      el.dataset.for = form.id;
      form.insertAdjacentElement('afterend', el);
    }
    el.textContent = message;
  }

  function clearError(form: HTMLFormElement) {
    const el = form.parentElement?.querySelector<HTMLElement>(`.waitlist-error[data-for="${form.id}"]`);
    el?.remove();
  }
</script>
