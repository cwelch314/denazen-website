---
import { defaultLang, locales, type Lang } from '../i18n/config';
import { useTranslations, localizePath, stripLangFromPath } from '../i18n/utils';
import { localizeAsset } from '../i18n/assets';

interface Props {
  currentPath: string;
  lang?: Lang;
  langlessPath?: string;
}
const { currentPath, lang = defaultLang, langlessPath } = Astro.props;
const t = useTranslations(lang);
const basePath = langlessPath ?? stripLangFromPath(currentPath);

const links = [
  { key: 'nav.home' as const, path: '/', mobileOnly: true },
  { key: 'nav.about' as const, path: '/about/' },
  { key: 'nav.faq' as const, path: '/faq/' },
  { key: 'nav.security' as const, path: '/security/' },
];

const isActive = (path: string) => {
  if (path === '/') return basePath === '/';
  return basePath.startsWith(path);
};

const linkClass = (link: { mobileOnly?: boolean }, active: boolean) =>
  [active ? 'active' : null, link.mobileOnly ? 'mobile-only' : null]
    .filter(Boolean)
    .join(' ');
---
<header class="site-nav">
  <div class="container site-nav-inner">
    <a href={localizePath('/', lang)} class="brand" aria-label={t('nav.brandAria')}>
      <img src={localizeAsset('/images/brand/fox-64.png', lang)} alt="" class="brand-fox" width="32" height="32" />
      <span class="brand-text">Denazen</span>
    </a>
    <div class="nav-right">
      <nav id="primary-nav" class="nav-links" aria-label={t('nav.primaryAria')}>
        {links.map((l) => (
          <a href={localizePath(l.path, lang)} class={linkClass(l, isActive(l.path))} aria-current={isActive(l.path) ? 'page' : undefined}>{t(l.key)}</a>
        ))}
        <a href={`${localizePath('/', lang)}#waitlist`} class="btn btn-primary">{t('nav.requestInvite')}</a>
      </nav>
      <div class="lang-switcher" role="group" aria-label={t('nav.languageAria')}>
        {locales.map((loc) => (
          <a
            href={localizePath(basePath, loc)}
            class={`lang-link ${loc === lang ? 'active' : ''}`}
            hreflang={loc}
            aria-current={loc === lang ? 'true' : undefined}
          >{loc.toUpperCase()}</a>
        ))}
      </div>
      <button
        class="nav-toggle"
        type="button"
        aria-label={t('nav.toggleAria')}
        aria-expanded="false"
        aria-controls="primary-nav"
        data-nav-toggle
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const nav = document.getElementById('primary-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(!!open));
  });
</script>
